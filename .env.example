# Copy to .env and fill in. The .env file is gitignored.
#
# ---------------------------------------------------------------------------
# Secrets rotation policy
# ---------------------------------------------------------------------------
# Every variable marked "(secret)" below must be rotated on a schedule and
# any time you suspect compromise, an employee with access leaves, or you
# release a new major version. Recommended cadences:
#
#   * SECRET_KEY_BASE, JWT_SECRET ............... every 90 days
#   * AR_ENCRYPTION_* (deterministic + primary) . every 180 days, with a
#                                                 dual-key migration window
#   * SIDEKIQ_WEB_PASSWORD ...................... every 90 days
#   * OPENAI_API_KEY, OAuth provider secrets .... every 180 days, or
#                                                 immediately if leaked
#   * SENTRY_DSN ................................ on project re-key only
#
# Rotation steps for the symmetric secrets (SECRET_KEY_BASE / JWT_SECRET /
# SIDEKIQ_WEB_PASSWORD):
#   1. Generate a new value (commands documented next to each variable).
#   2. Add it to your secrets manager (AWS Secrets Manager / Vault / GCP SM).
#   3. Roll a deploy that reads the new value. Sessions issued with the
#      previous JWT_SECRET become invalid — communicate the brief sign-out
#      to users in advance, or run with both secrets accepted for a window
#      using the standard JWT key-id ("kid") header.
#   4. Audit `audit_logs` for the rotation event.
#
# Rotation steps for AR_ENCRYPTION_* keys (encrypts integration credentials):
#   1. Run `bundle exec rails db:encryption:init` to mint new keys, but
#      do NOT replace the live keys yet.
#   2. Add the new keys as "next" via Rails 7's deterministic-encryption
#      key rotation (see Rails Guides → ActiveRecord::Encryption).
#   3. Re-encrypt records with `Integration.find_each(&:save!)` or a
#      background job; verify with `audit_logs` that no failures occurred.
#   4. Promote the new key to primary, demote the old key to "previous"
#      for read-only fallback, then remove it after one full backup cycle.
#
# Never commit a real .env. Never paste secrets in PRs, Slack, or chat
# logs. The CI matrix runs without these — production gets them from the
# secrets manager only.

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/vopro_development
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ---------------------------------------------------------------------------
# Redis (Sidekiq + Rack::Attack)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Rails
# ---------------------------------------------------------------------------
RAILS_ENV=development
# (secret) Rotate every 90 days. Generate with: openssl rand -hex 32
SECRET_KEY_BASE=
# (secret) Rotate every 90 days. Generate with: openssl rand -hex 32
# Rotation invalidates outstanding JWTs — schedule during low-traffic window
# or run with a kid-aware accept-both period.
JWT_SECRET=
ALLOWED_ORIGINS=http://localhost:5173

# Sidekiq Web UI HTTP Basic credentials (required outside the test env).
# These MUST NOT match any real Vopro user account credentials.
SIDEKIQ_WEB_USER=admin
# (secret) Rotate every 90 days. Generate with: openssl rand -base64 24
SIDEKIQ_WEB_PASSWORD=
# Optional comma-separated CIDR allowlist (e.g. "10.0.0.0/8,192.168.0.0/16").
# When set, requests from any other source IP are 403'd before HTTP Basic
# even runs. Leave blank to allow all IPs that pass HTTP Basic.
SIDEKIQ_WEB_ALLOWED_IPS=
# Set to "true" only for tests that exercise the dashboard itself; default
# off so a misconfigured CI run can't accidentally expose it.
SIDEKIQ_WEB_ENABLED=

# ActiveRecord encryption (encrypts integration secrets at rest).
# (secret) Rotate every 180 days using Rails' multi-key rotation flow —
# never just overwrite, or every encrypted column becomes unreadable.
# Generate with: cd backend && bundle exec rails db:encryption:init
AR_ENCRYPTION_PRIMARY_KEY=
AR_ENCRYPTION_DETERMINISTIC_KEY=
AR_ENCRYPTION_KEY_DERIVATION_SALT=

# ---------------------------------------------------------------------------
# AI Engine
# ---------------------------------------------------------------------------
# "openai" to call the real LLM; "deterministic" for offline templates.
VOPRO_LLM_PROVIDER=deterministic
# (secret) Rotate every 180 days, immediately if leaked. Use a project-
# scoped key with the lowest necessary spend cap.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
VOPRO_AI_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Observability (Sentry, optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Set per-deploy to a git sha or release tag.
SENTRY_RELEASE=

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000
VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Desktop Agent
# ---------------------------------------------------------------------------
VOPRO_API_BASE_URL=http://localhost:3000
VOPRO_DEVICE_ID=

# ---------------------------------------------------------------------------
# OAuth (per-provider, optional)
# ---------------------------------------------------------------------------
OAUTH_REDIRECT_BASE=http://localhost:3000
# Comma-separated list of trusted frontend origins. Used as the targetOrigin
# when the OAuth callback popup posts back to the opener. Required in prod
# (anything else widens postMessage to "*"). Example:
#   FRONTEND_ORIGIN=https://app.vopro.com,https://staging.vopro.com
FRONTEND_ORIGIN=
# (secret) OAuth client secrets — rotate every 180 days. Generate from the
# provider's console, paste here, redeploy. Never commit real values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
